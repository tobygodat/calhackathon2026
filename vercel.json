{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix baskr/frontend ci",
  "buildCommand": "npm --prefix baskr/frontend run build",
  "outputDirectory": "baskr/frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://calhackathon2026.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
