# Baskr data pipeline — environment configuration.
# Copy to ".env" (same folder) and fill in. ALL KEYS ARE OPTIONAL:
# the pipeline runs against every source with no keys at all. Keys only raise
# rate limits (NCBI) or unlock richer abstracts (Springer Nature).

# Contact email — sent to NCBI E-utilities and Crossref so your traffic is
# identified ("polite pool") instead of anonymously throttled. Recommended.
PIPELINE_CONTACT_EMAIL=drewrhawley@gmail.com
PIPELINE_TOOL_NAME=baskr

# --- OPTIONAL: NCBI / PubMed -------------------------------------------------
# Raises PubMed rate limit from 3 -> 10 requests/sec. Free.
# Get one: https://www.ncbi.nlm.nih.gov/account/  ->  Account Settings
#          ->  "API Key Management"  ->  Create an API Key
# NCBI_API_KEY=

# --- OPTIONAL: Springer Nature (richer Nature abstracts/full text) -----------
# Without this, Nature is fetched via the keyless Crossref path (metadata +
# many abstracts). With it, the Springer Nature portfolio API is used. Free.
# Register: https://dev.springernature.com/  ->  create app  ->  copy API key
# SPRINGER_API_KEY=

# --- OPTIONAL: Sentry error monitoring ---------------------------------------
# Set to your Sentry DSN to report unhandled exceptions from the CLI. When
# unset, error monitoring is disabled (no-op). Find it in Sentry under
# Project Settings -> Client Keys (DSN).
# SENTRY_DSN=

# --- OPTIONAL: pipeline defaults ---------------------------------------------
# PIPELINE_LOOKBACK_DAYS=7
# PIPELINE_MAX_PER_SOURCE=50
# PIPELINE_HTTP_TIMEOUT=30

# arXiv and bioRxiv require NO key — nothing to configure.
