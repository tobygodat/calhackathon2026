# --- Baskr backend ---
# Paper fetching is delegated to implementations/data_pipeline, which has its own
# optional keys (NCBI_API_KEY, SPRINGER_API_KEY, PIPELINE_CONTACT_EMAIL). Those can
# live here too — the pipeline reads them from the environment.

NCBI_API_KEY=             # free; raises PubMed rate limit ~3 -> ~10 req/sec
OPENAI_API_KEY=           # embeddings (text-embedding-3-small)
ANTHROPIC_API_KEY=        # reasoning LLM (Claude)
REDIS_URL=                # e.g. redis://localhost:6379

BASKR_LAB_ID=gut-microbiome-demo
BASKR_RELEVANCE_THRESHOLD=0.5
EMBED_MODEL=text-embedding-3-small
REASON_MODEL=             # confirm current recommended claude-* model at build time

# --- data_pipeline (optional, see implementations/data_pipeline/.env.example) ---
SPRINGER_API_KEY=
PIPELINE_CONTACT_EMAIL=
